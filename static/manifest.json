    },
    {
      "name": "Split PDF",
      "short_name": "Split",
      "description": "Split a PDF into separate files",
      "url": "/tools/split-pdf?source=pwa-shortcut",
      "icons": [{ "src": "/assets/meta/web-app-manifest-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Compress PDF",
      "short_name": "Compress",
      "description": "Reduce PDF file size",
      "url": "/tools/compress-pdf?source=pwa-shortcut",
      "icons": [{ "src": "/assets/meta/web-app-manifest-192x192.png", "sizes": "192x192" }]
    }
  ]
